        "text": "=🆕 *New signup*\n\n*Name:* {{ $json.first_name }} {{ $json.surname }}\n*Email:* `{{ $json.email }}`\n*Source:* {{ $json.source }}\n*Use case:* {{ $json.use_case || '—' }}\n\n🔎 Already in CRM: *{{ $json.known_in_crm === 'yes' ? 'YES' : 'no' }}*{{ $json.known_in_crm === 'yes' ? `\\n\\n📇 In CRM as *${$('CRM Lookup').first().json.status || 'contact'}*${$('CRM Lookup').first().json.groups ? ' · ' + $('CRM Lookup').first().json.groups : ''}\\n🗒 Last topic: ${$('CRM Lookup').first().json.last_topic || '—'}\\n📅 Since: ${($('CRM Lookup').first().json.contact_created_at || '').toString().slice(0, 10) || '—'}` : '' }}",
        "additionalFields": {
          "appendAttribution": false,
          "parse_mode": "Markdown"
        },
